+const webConfigUrl = () => {
+  const root = document.getElementById('root')
+  const pathPrefix = root ? root.getAttribute('data-path-prefix') : ''
+  if (!pathPrefix || pathPrefix === '__PATH_PREFIX__') {
+    return '/config.json'
+  }
+
+  const normalizedPrefix = pathPrefix.replace(/\/+$/, '')
+  const signInIndex = normalizedPrefix.indexOf('/signin/v1')
+  if (signInIndex <= 0) {
+    return '/config.json'
+  }
+
+  return `${normalizedPrefix.slice(0, signInIndex)}/config.json`
+}
