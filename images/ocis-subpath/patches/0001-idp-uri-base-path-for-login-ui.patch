+func pathWithOptionalPrefix(prefix string, subpath string) string {
+	prefix = strings.TrimSuffix(prefix, "/")
+	subpath = "/" + strings.Trim(subpath, "/")
+	if prefix == "" || prefix == "/" {
+		return subpath
+	}
+	if !strings.HasPrefix(prefix, "/") {
+		prefix = "/" + prefix
+	}
+	return prefix + subpath
+}
