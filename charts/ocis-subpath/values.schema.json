{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "image",
    "ocis",
    "service",
    "webAssetsPatcher"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "webAssetsPatcher": {
      "type": "object",
      "required": ["enabled", "image", "srcDist", "dstDist", "configOut", "apps", "options", "extraConfig"],
      "properties": {
        "enabled": { "type": "boolean" },
        "srcDist": { "type": "string", "minLength": 1 },
        "dstDist": { "type": "string", "minLength": 1 },
        "configOut": { "type": "string", "minLength": 1 },
        "oidcClientId": { "type": "string", "minLength": 1 },
        "oidcScope": { "type": "string", "minLength": 1 },
        "themePath": { "type": "string", "pattern": "^/" },
        "apps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "options": { "type": "object" },
        "extraConfig": { "type": "object" },
        "patchAbsoluteUrls": { "type": "boolean" },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "ocis": {
      "type": "object",
      "required": ["baseUrl", "subpath", "oidc"],
      "properties": {
        "baseUrl": { "type": "string", "pattern": "^https?://" },
        "subpath": { "type": "string", "pattern": "^(/.*)?$" },
        "publicUrlOverride": { "type": "string" },
        "logLevel": { "type": "string" },
        "insecure": { "type": "boolean" },
        "proxyTls": { "type": "boolean" },
        "csp": {
          "type": "object",
          "required": ["enabled", "directives"],
          "properties": {
            "enabled": { "type": "boolean" },
            "directives": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "env": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
        "existingSecret": { "type": "string" },
        "generatedSecrets": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "secrets": {
          "type": "object",
          "required": ["adminPasswordKey", "jwtSecretKey", "transferSecretKey", "machineAuthApiKeyKey"],
          "properties": {
            "adminPasswordKey": { "type": "string", "minLength": 1 },
            "jwtSecretKey": { "type": "string", "minLength": 1 },
            "transferSecretKey": { "type": "string", "minLength": 1 },
            "machineAuthApiKeyKey": { "type": "string", "minLength": 1 }
          }
        },
        "oidc": {
          "type": "object",
          "properties": {
            "issuer": { "type": "string" },
            "rewriteWellknown": { "type": "boolean" },
            "metadataUrl": { "type": "string" },
            "authority": { "type": "string" }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "hostAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ip", "hostnames"],
        "properties": {
          "ip": { "type": "string", "minLength": 1 },
          "hostnames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "pathType"],
                  "properties": {
                    "path": { "type": "string", "pattern": "^/" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array" }
      }
    }
  }
}
