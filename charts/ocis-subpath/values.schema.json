{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "image",
    "ocis",
    "service",
    "webAssetsPatcher"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "deploymentStrategy": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["type"],
            "properties": {
              "type": { "const": "Recreate" }
            }
          },
          "then": {
            "not": {
              "required": ["rollingUpdate"]
            }
          }
        }
      ],
      "properties": {
        "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] },
        "rollingUpdate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxSurge": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string", "pattern": "^[0-9]+%$" }
              ]
            },
            "maxUnavailable": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string", "pattern": "^[0-9]+%$" }
              ]
            }
          }
        }
      }
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "webAssetsPatcher": {
      "type": "object",
      "required": ["enabled", "image", "srcDist", "dstDist", "configOut", "apps", "options", "extraConfig"],
      "properties": {
        "enabled": { "type": "boolean" },
        "srcDist": { "type": "string", "minLength": 1 },
        "dstDist": { "type": "string", "minLength": 1 },
        "configOut": { "type": "string", "minLength": 1 },
        "oidcClientId": { "type": "string", "minLength": 1 },
        "oidcScope": { "type": "string", "minLength": 1 },
        "themePath": { "type": "string", "pattern": "^/" },
        "apps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "options": { "type": "object" },
        "extraConfig": { "type": "object" },
        "patchAbsoluteUrls": { "type": "boolean" },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "drawio": {
      "type": "object",
      "required": ["enabled", "editorUrl", "ui", "protocol", "formats", "webApp", "csp"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["enabled"],
            "properties": {
              "enabled": { "const": true }
            }
          },
          "then": {
            "properties": {
              "editorUrl": { "type": "string", "minLength": 1, "pattern": "^https?://" }
            }
          }
        }
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "editorUrl": {
          "type": "string",
          "description": "Absolute diagrams.net embed editor URL. Use this to switch between public embed.diagrams.net and a self-hosted draw.io server.",
          "pattern": "^$|^https?://"
        },
        "ui": { "type": "string", "minLength": 1 },
        "protocol": { "type": "string", "enum": ["json"] },
        "formats": {
          "type": "object",
          "required": ["drawio", "drawioSvg"],
          "additionalProperties": false,
          "properties": {
            "drawio": {
              "type": "object",
              "required": ["enabled", "extension", "mimeType"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "extension": { "type": "string", "minLength": 1 },
                "mimeType": { "type": "string", "minLength": 1 }
              }
            },
            "drawioSvg": {
              "type": "object",
              "required": ["enabled", "extension", "mimeType"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "extension": { "type": "string", "minLength": 1 },
                "mimeType": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "webApp": {
          "type": "object",
          "required": ["enabled", "name", "path", "displayName"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "path": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^/].*/[^/]+\\.js$",
              "description": "Relative path under the patched Web assets where the generated draw.io Web app is served."
            },
            "displayName": { "type": "string", "minLength": 1 }
          }
        },
        "csp": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "ocis": {
      "type": "object",
      "required": ["baseUrl", "subpath", "oidc"],
      "properties": {
        "baseUrl": { "type": "string", "pattern": "^https?://" },
        "subpath": { "type": "string", "pattern": "^(/.*)?$" },
        "publicUrlOverride": { "type": "string" },
        "logLevel": { "type": "string" },
        "insecure": { "type": "boolean" },
        "proxyTls": { "type": "boolean" },
        "csp": {
          "type": "object",
          "required": ["enabled", "directives"],
          "properties": {
            "enabled": { "type": "boolean" },
            "directives": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "env": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
        "existingSecret": { "type": "string" },
        "generatedSecrets": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "secrets": {
          "type": "object",
          "required": ["adminPasswordKey", "jwtSecretKey", "transferSecretKey", "machineAuthApiKeyKey"],
          "properties": {
            "adminPasswordKey": { "type": "string", "minLength": 1 },
            "jwtSecretKey": { "type": "string", "minLength": 1 },
            "transferSecretKey": { "type": "string", "minLength": 1 },
            "machineAuthApiKeyKey": { "type": "string", "minLength": 1 }
          }
        },
        "oidc": {
          "type": "object",
          "allOf": [
            {
              "if": {
                "properties": {
                  "external": {
                    "properties": {
                      "enabled": { "const": true }
                    }
                  }
                }
              },
              "then": {
                "anyOf": [
                  {
                    "required": ["issuer"],
                    "properties": {
                      "issuer": { "type": "string", "minLength": 1, "pattern": "^https?://" }
                    }
                  },
                  {
                    "required": ["authority"],
                    "properties": {
                      "authority": { "type": "string", "minLength": 1, "pattern": "^https?://" }
                    }
                  }
                ]
              }
            }
          ],
          "properties": {
            "external": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            },
            "issuer": {
              "type": "string",
              "description": "External OIDC issuer URL. Its origin is automatically added to CSP connect-src when external.enabled=true.",
              "pattern": "^$|^https?://"
            },
            "rewriteWellknown": { "type": "boolean" },
            "metadataUrl": {
              "type": "string",
              "description": "External OIDC discovery metadata URL. Its origin is automatically added to CSP connect-src when external.enabled=true.",
              "pattern": "^$|^https?://"
            },
            "authority": {
              "type": "string",
              "description": "External OIDC authority URL. Its origin is automatically added to CSP connect-src when external.enabled=true.",
              "pattern": "^$|^https?://"
            }
          }
        },
        "roleAssignment": {
          "type": "object",
          "allOf": [
            {
              "if": {
                "required": ["enabled", "mode"],
                "properties": {
                  "enabled": { "const": true },
                  "mode": { "const": "group" }
                }
              },
              "then": {
                "required": ["driver", "mode", "groupClaim", "groupMapping"],
                "properties": {
                  "groupClaim": { "type": "string", "minLength": 1 }
                }
              }
            },
            {
              "if": {
                "required": ["enabled", "mode"],
                "properties": {
                  "enabled": { "const": true },
                  "mode": { "const": "user" }
                }
              },
              "then": {
                "required": ["driver", "mode", "userClaim", "userMapping"],
                "properties": {
                  "userClaim": { "type": "string", "minLength": 1 }
                }
              }
            },
            {
              "if": {
                "required": ["enabled", "mode"],
                "properties": {
                  "enabled": { "const": true },
                  "mode": { "const": "auto" }
                }
              },
              "then": {
                "required": ["driver", "mode"]
              }
            }
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "driver": {
              "type": "string",
              "enum": ["oidc"]
            },
            "mode": {
              "type": "string",
              "enum": ["auto", "group", "user"],
              "description": "Selects which OIDC claim is used for role assignment. auto uses groupMapping when non-empty, otherwise userMapping."
            },
            "groupClaim": { "type": "string" },
            "groupMapping": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "admin": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "spaceadmin": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "user": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "guest": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              }
            },
            "userClaim": { "type": "string" },
            "userMapping": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "admin": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "spaceadmin": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "user": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "guest": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              }
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "hostAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ip", "hostnames"],
        "properties": {
          "ip": { "type": "string", "minLength": 1 },
          "hostnames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "traefik": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "entryPoints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["host"],
            "properties": {
              "host": { "type": "string", "minLength": 1 }
            }
          }
        },
        "tls": { "type": "object" }
      }
    }
  }
}
